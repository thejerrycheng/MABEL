<mujoco model="mabel_mobile_base_component">
    <asset>
        <material name="base_chassis_mat" rgba="0.7 0.7 0.7 1"/>
        <material name="wheel_mat" rgba="0.1 0.1 0.1 1"/>
        
        <material name="steer_motor_mat" rgba="0.2 0.4 0.8 1"/>
        <material name="drive_motor_mat" rgba="0.8 0.3 0.3 1"/>
    </asset>

    <worldbody>
        <body name="chassis" pos="0 0 0.15">
            <geom type="box" size="0.3 0.2 0.05" material="base_chassis_mat" mass="15"/>
            
            <site name="lift_mount_point" pos="0 0 0.05" size="0.01" rgba="0 1 0 1"/>

            <body name="swerve_fl" pos="0.25 0.15 -0.05">
                <joint name="steer_fl" type="hinge" axis="0 0 1" limited="false" damping="0.5" frictionloss="0.1"/>
                
                <geom type="cylinder" size="0.02 0.04" pos="0.04 0 0.05" material="steer_motor_mat" contype="0" conaffinity="0" mass="0.5"/>
                <geom type="cylinder" size="0.035 0.06" pos="-0.04 0 0.05" material="drive_motor_mat" contype="0" conaffinity="0" mass="1.0"/>
                
                <body name="wheel_fl" pos="0 0 -0.05">
                    <joint name="drive_fl" type="hinge" axis="0 1 0" damping="0.05"/>
                    <geom type="cylinder" size="0.05 0.02" euler="90 0 0" material="wheel_mat" mass="0.5" friction="1 0.005 0.0001"/>
                </body>
            </body>

            <body name="swerve_fr" pos="0.25 -0.15 -0.05">
                <joint name="steer_fr" type="hinge" axis="0 0 1" limited="false" damping="0.5" frictionloss="0.1"/>
                
                <geom type="cylinder" size="0.02 0.04" pos="0.04 0 0.05" material="steer_motor_mat" contype="0" conaffinity="0" mass="0.5"/>
                <geom type="cylinder" size="0.035 0.06" pos="-0.04 0 0.05" material="drive_motor_mat" contype="0" conaffinity="0" mass="1.0"/>
                
                <body name="wheel_fr" pos="0 0 -0.05">
                    <joint name="drive_fr" type="hinge" axis="0 1 0" damping="0.05"/>
                    <geom type="cylinder" size="0.05 0.02" euler="90 0 0" material="wheel_mat" mass="0.5" friction="1 0.005 0.0001"/>
                </body>
            </body>

            <body name="swerve_bc" pos="-0.25 0 -0.05">
                <joint name="steer_bc" type="hinge" axis="0 0 1" limited="false" damping="0.5" frictionloss="0.1"/>
                
                <geom type="cylinder" size="0.02 0.04" pos="0.04 0 0.05" material="steer_motor_mat" contype="0" conaffinity="0" mass="0.5"/>
                <geom type="cylinder" size="0.035 0.06" pos="-0.04 0 0.05" material="drive_motor_mat" contype="0" conaffinity="0" mass="1.0"/>
                
                <body name="wheel_bc" pos="0 0 -0.05">
                    <joint name="drive_bc" type="hinge" axis="0 1 0" damping="0.05"/>
                    <geom type="cylinder" size="0.05 0.02" euler="90 0 0" material="wheel_mat" mass="0.5" friction="1 0.005 0.0001"/>
                </body>
            </body>

        </body>
    </worldbody>

    <actuator>
        <position name="act_steer_fl" joint="steer_fl" kp="50" kv="5"/>
        <position name="act_steer_fr" joint="steer_fr" kp="50" kv="5"/>
        <position name="act_steer_bc" joint="steer_bc" kp="50" kv="5"/>

        <velocity name="act_drive_fl" joint="drive_fl" kv="10"/>
        <velocity name="act_drive_fr" joint="drive_fr" kv="10"/>
        <velocity name="act_drive_bc" joint="drive_bc" kv="10"/>
    </actuator>
</mujoco>