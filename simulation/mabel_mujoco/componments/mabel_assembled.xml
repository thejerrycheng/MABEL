<mujoco model="mabel_assembled">
    <option gravity="0 0 -9.81" timestep="0.002" integrator="implicitfast"/>

    <asset>
        <material name="lift_outer_mat" rgba="0.2 0.2 0.2 1"/>
        <material name="lift_middle_mat" rgba="0.5 0.5 0.5 1"/>
        <material name="lift_inner_mat" rgba="0.8 0.8 0.8 1"/>
        
        <material name="base_chassis_mat" rgba="0.7 0.7 0.7 1"/>
        <material name="wheel_mat" rgba="0.1 0.1 0.1 1"/>
        <material name="steer_motor_mat" rgba="0.2 0.4 0.8 1"/>
        <material name="drive_motor_mat" rgba="0.8 0.3 0.3 1"/>
    </asset>

    <worldbody>
        <body name="chassis" pos="0 0 0.17">
            <freejoint name="base_freejoint"/>
            
            <geom type="box" size="0.25 0.25 0.05" material="base_chassis_mat" mass="40" contype="1" conaffinity="0"/>
            
            <geom type="box" pos="0.15 0 0.35" size="0.04 0.04 0.3" material="lift_inner_mat" mass="2" contype="1" conaffinity="0"/>

            <geom name="steer_motor_fl" type="cylinder" size="0.02 0.04" pos="0.15 0.2 0.0" material="steer_motor_mat" mass="0.5" contype="1" conaffinity="0"/>
            <geom name="steer_motor_fr" type="cylinder" size="0.02 0.04" pos="0.15 -0.2 0.0" material="steer_motor_mat" mass="0.5" contype="1" conaffinity="0"/>
            <geom name="steer_motor_bc" type="cylinder" size="0.02 0.04" pos="-0.15 0 0.0" material="steer_motor_mat" mass="0.5" contype="1" conaffinity="0"/>

            <body name="lift_middle" pos="0.15 0 0.45">
                <joint name="slide_middle" type="slide" axis="0 0 1" range="-0.02 0.42" limited="true" armature="1" frictionloss="2" damping="2"/>
                <geom type="box" size="0.05 0.05 0.3" material="lift_middle_mat" mass="1" contype="1" conaffinity="0"/>

                <body name="lift_top" pos="0 0 0.1">
                    <joint name="slide_top" type="slide" axis="0 0 1" range="-0.02 0.42" limited="true" armature="1" frictionloss="2" damping="2"/>
                    <geom type="box" size="0.06 0.06 0.3" material="lift_outer_mat" mass="1" contype="1" conaffinity="0"/>
                    <site name="torso_mount_point" pos="0 0 0.3" size="0.01" rgba="1 0 0 1"/>
                </body>
            </body>

            <body name="swerve_fl" pos="0.2 0.2 -0.06">
                <joint name="steer_fl" type="hinge" axis="0 0 1" limited="false" damping="0.5" frictionloss="0.1"/>
                <geom type="cylinder" size="0.035 0.05" pos="0 0 0.03" material="drive_motor_mat" mass="1.0" contype="1" conaffinity="0"/>
                
                <body name="wheel_fl" pos="0 0 -0.05">
                    <joint name="drive_fl" type="hinge" axis="0 1 0" damping="0.05"/>
                    <geom type="cylinder" size="0.05 0.02" euler="90 0 0" material="wheel_mat" mass="0.5" friction="1 0.005 0.0001" contype="1" conaffinity="0"/>
                </body>
            </body>

            <body name="swerve_fr" pos="0.2 -0.2 -0.06">
                <joint name="steer_fr" type="hinge" axis="0 0 1" limited="false" damping="0.5" frictionloss="0.1"/>
                <geom type="cylinder" size="0.035 0.05" pos="0 0 0.03" material="drive_motor_mat" mass="1.0" contype="1" conaffinity="0"/>
                
                <body name="wheel_fr" pos="0 0 -0.05">
                    <joint name="drive_fr" type="hinge" axis="0 1 0" damping="0.05"/>
                    <geom type="cylinder" size="0.05 0.02" euler="90 0 0" material="wheel_mat" mass="0.5" friction="1 0.005 0.0001" contype="1" conaffinity="0"/>
                </body>
            </body>

            <body name="swerve_bc" pos="-0.2 0 -0.06">
                <joint name="steer_bc" type="hinge" axis="0 0 1" limited="false" damping="0.5" frictionloss="0.1"/>
                <geom type="cylinder" size="0.035 0.05" pos="0 0 0.03" material="drive_motor_mat" mass="1.0" contype="1" conaffinity="0"/>
                
                <body name="wheel_bc" pos="0 0 -0.05">
                    <joint name="drive_bc" type="hinge" axis="0 1 0" damping="0.05"/>
                    <geom type="cylinder" size="0.05 0.02" euler="90 0 0" material="wheel_mat" mass="0.5" friction="1 0.005 0.0001" contype="1" conaffinity="0"/>
                </body>
            </body>

        </body>
    </worldbody>

    <contact>
        <exclude body1="chassis" body2="wheel_fl"/>
        <exclude body1="chassis" body2="wheel_fr"/>
        <exclude body1="chassis" body2="wheel_bc"/>
        <exclude body1="chassis" body2="lift_middle"/>
        <exclude body1="chassis" body2="lift_top"/>
    </contact>

    <equality>
        <joint joint1="slide_top" joint2="slide_middle" polycoef="0 1 0 0 0" solimp="0.8 0.99 0.001" solref="0.02 1"/>
    </equality>

    <actuator>
        <position name="act_lift" joint="slide_middle" kp="800" kv="50" ctrlrange="0 0.4" ctrllimited="true"/>

        <position name="act_steer_fl" joint="steer_fl" kp="20" kv="2" forcerange="-5 5"/>
        <position name="act_steer_fr" joint="steer_fr" kp="20" kv="2" forcerange="-5 5"/>
        <position name="act_steer_bc" joint="steer_bc" kp="20" kv="2" forcerange="-5 5"/>

        <velocity name="act_drive_fl" joint="drive_fl" kv="5" forcerange="-8 8"/>
        <velocity name="act_drive_fr" joint="drive_fr" kv="5" forcerange="-8 8"/>
        <velocity name="act_drive_bc" joint="drive_bc" kv="5" forcerange="-8 8"/>
    </actuator>
</mujoco>