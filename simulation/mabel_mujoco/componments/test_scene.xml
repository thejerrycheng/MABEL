<mujoco model="mabel_test_scene">
    <option gravity="0 0 -9.81" timestep="0.005" integrator="RK4"/>

    <asset>
        <texture type="2d" name="grid" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 .2 .3" width="300" height="300" mark="edge" markrgb=".2 .3 .4"/>
        <material name="grid_mat" texture="grid" texrepeat="5 5" texuniform="true" reflectance=".1"/>
    </asset>

    <include file="mabel_assembled.xml"/>

    <worldbody>
        <light diffuse=".8 .8 .8" pos="0 0 5" dir="0 0 -1"/>
        
        <geom type="plane" size="5 5 0.1" material="grid_mat" friction="1.5 0.005 0.0001"/>

        <body name="obstacle_box" pos="1 0 0.1">
            <freejoint/>
            <geom type="box" size="0.2 0.2 0.1" rgba="0.8 0.6 0.2 1" mass="2"/>
        </body>

        <body name="obstacle_cylinder" pos="-1 1 0.2">
            <freejoint/>
            <geom type="cylinder" size="0.2 0.2" rgba="0.2 0.8 0.6 1" mass="5"/>
        </body>
    </worldbody>
</mujoco>